        </div>
        <Stats
            client:visible
            totals={totals}
            days={days}
            codingByLanguage={codingByLanguage}
            heatmapDays={heatmapDays}
            heatmapCodingByLanguage={heatmapCodingByLanguage}
        />
        <div class="my-8">
            <h2 class="text-primary font-semibold text-xl">contact</h2>
            <ul class="flex flex-wrap items-center gap-4 mt-2 text-lg text-secondary">
                <a
                    class=" underline"
