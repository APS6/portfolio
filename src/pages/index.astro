---
import Layout from "../layouts/Layout.astro";
import Face from "../components/face.astro";
import Stats from "../components/stats.svelte"

import { db, current_status, stats_day, coding_by_language, gte } from "astro:db";

const statusPromise = db.select().from(current_status).limit(1);

const now = Math.floor(Date.now() / 1000);

const month_ago = now - 30 * 24 * 60 * 60;
const three_months_ago = now - 90 * 24 * 60 * 60;

const daysPromise = db
  .select({
    timestamp: stats_day.timestamp,
    keystrokes: stats_day.keystrokes,
    keybinds: stats_day.keybinds,
    mouse_clicks: stats_day.mouse_clicks,
    mouse_distance_mm: stats_day.mouse_distance_mm,
    mouse_scroll_mm: stats_day.mouse_scroll_mm,
    chars_written: stats_day.chars_written,
    active_minutes: stats_day.active_minutes,
    coding_minutes: stats_day.coding_minutes,
  })
  .from(stats_day)
  .where(gte(stats_day.timestamp, month_ago))
  .orderBy((table) => table.timestamp);

const codingByLanguagePromise = db
  .select({
    date: coding_by_language.date,
    language: coding_by_language.language,
    seconds: coding_by_language.seconds,
    chars_written: coding_by_language.chars_written,
  })
  .from(coding_by_language)
  .where(gte(coding_by_language.date, month_ago))
  .orderBy((table) => table.date);

const heatmapDaysPromise = db
  .select({
    timestamp: stats_day.timestamp,
    git_commits: stats_day.git_commits,
  })
  .from(stats_day)
  .where(gte(stats_day.timestamp, three_months_ago))
  .orderBy((table) => table.timestamp);

const heatmapCodingByLanguagePromise = db
  .select({
    date: coding_by_language.date,
    seconds: coding_by_language.seconds,
  })
  .from(coding_by_language)
  .where(gte(coding_by_language.date, three_months_ago))
  .orderBy((table) => table.date);

const [[status], days, codingByLanguage, heatmapDays, heatmapCodingByLanguage] =
  await Promise.all([
    statusPromise,
    daysPromise,
    codingByLanguagePromise,
    heatmapDaysPromise,
    heatmapCodingByLanguagePromise,
  ]);


const is_online = !!status && now - status.last_activity_at <= 300;
const is_coding = !!status && now - status.last_coding_at <= 300;


const totals = days.reduce(
  (acc, day) => ({
    keystrokes: acc.keystrokes + (day.keystrokes ?? 0),
    keybinds: acc.keybinds + (day.keybinds ?? 0),
    mouse_clicks: acc.mouse_clicks + (day.mouse_clicks ?? 0),
    mouse_distance_mm: acc.mouse_distance_mm + (day.mouse_distance_mm ?? 0),
    mouse_scroll_mm: acc.mouse_scroll_mm + (day.mouse_scroll_mm ?? 0),
    chars_written: acc.chars_written + (day.chars_written ?? 0),
    active_minutes: acc.active_minutes + (day.active_minutes ?? 0),
    coding_minutes: acc.coding_minutes + (day.coding_minutes ?? 0),
  }),
  {
    keystrokes: 0,
    keybinds: 0,
    mouse_clicks: 0,
    mouse_distance_mm: 0,
    mouse_scroll_mm: 0,
    chars_written: 0,
    active_minutes: 0,
    coding_minutes: 0,
  }
);
---

<Layout>
    <div class="px-2 lg:px-0">
        <nav
